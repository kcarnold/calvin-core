{
  "manifest_version": 3,
  "name": "Calvin Core Annotator",
  "version": "0.1.0",
  "description": "Annotate Calvin's core curriculum page using a pasted Workday Academic History transcript.",
  "content_scripts": [
    {
      "matches": [
        "https://catalog.calvin.edu/content.php*"
      ],
      "js": [
        "dist/extension.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/pdf.worker.min.mjs"],
      "matches": ["https://catalog.calvin.edu/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "calvin-core-annotator@kcarnold.github.com"
    }
  }
}